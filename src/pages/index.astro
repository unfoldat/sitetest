---
import Base from '../layouts/Base.astro';
---
<Base title="홈 메타 제목" description="홈 메타 설명" current="">
<main id="main">
  <!-- 히어로 -->
  <section class="hero" aria-labelledby="hero-h">
    <div class="wrap">
      <h1 id="hero-h">히어로 제목</h1>
      <p>히어로 설명문구</p>
      <div class="hero-cta">
        <a class="btn btn-amber" href="사업안내.html">히어로 버튼1</a>
        <a class="btn btn-ghost" href="후원참여.html">히어로 버튼2</a>
      </div>
    </div>
  </section>

  <!-- 빠른 연결 -->
  <section class="quicklinks" aria-labelledby="ql-h">
    <div class="wrap">
      <h2 id="ql-h" class="sr-only">빠른연결 영역 제목</h2>
      <div class="ql-grid">
        <a class="ql-card" href="사업안내.html#활동지원">
          <span class="ico" aria-hidden="true">🤝</span>
          <h3>빠른연결카드1 제목</h3>
          <p>빠른연결카드1 설명</p>
        </a>
        <a class="ql-card" href="사업안내.html#동료상담">
          <span class="ico" aria-hidden="true">💬</span>
          <h3>빠른연결카드2 제목</h3>
          <p>빠른연결카드2 설명</p>
        </a>
        <a class="ql-card" href="사업안내.html#권익옹호">
          <span class="ico" aria-hidden="true">⚖️</span>
          <h3>빠른연결카드3 제목</h3>
          <p>빠른연결카드3 설명</p>
        </a>
        <a class="ql-card" href="후원참여.html#후원신청">
          <span class="ico" aria-hidden="true">💛</span>
          <h3>빠른연결카드4 제목</h3>
          <p>빠른연결카드4 설명</p>
        </a>
      </div>
    </div>
  </section>

  <!-- 사업 소개 -->
  <section class="block alt" aria-labelledby="prog-h">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">사업소개 소제목</span>
        <h2 id="prog-h">사업소개 제목</h2>
        <p>사업소개 설명문구</p>
      </div>
      <div class="prog-grid">
        <div class="prog-card"><h3>사업카드1 제목</h3><p>사업카드1 설명</p></div>
        <div class="prog-card"><h3>사업카드2 제목</h3><p>사업카드2 설명</p></div>
        <div class="prog-card"><h3>사업카드3 제목</h3><p>사업카드3 설명</p></div>
        <div class="prog-card"><h3>사업카드4 제목</h3><p>사업카드4 설명</p></div>
        <div class="prog-card"><h3>사업카드5 제목</h3><p>사업카드5 설명</p></div>
      </div>
      <p style="margin-top:1.5rem;"><a class="btn btn-pine" href="사업안내.html">사업소개 버튼</a></p>
    </div>
  </section>

  <!-- 최신 소식 -->
  <section class="block" aria-labelledby="news-h">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">최신소식 소제목</span>
        <h2 id="news-h">최신소식 제목</h2>
      </div>
      <ul class="news-list">
        <li><a href="센터소식.html"><span class="t"><span class="badge notice">소식1 분류</span>소식1 제목</span><span class="date">소식1 날짜</span></a></li>
        <li><a href="센터소식.html"><span class="t"><span class="badge">소식2 분류</span>소식2 제목</span><span class="date">소식2 날짜</span></a></li>
        <li><a href="센터소식.html"><span class="t"><span class="badge notice">소식3 분류</span>소식3 제목</span><span class="date">소식3 날짜</span></a></li>
        <li><a href="센터소식.html"><span class="t"><span class="badge">소식4 분류</span>소식4 제목</span><span class="date">소식4 날짜</span></a></li>
      </ul>
      <p style="margin-top:1.3rem;"><a class="btn btn-pine" href="센터소식.html">최신소식 버튼</a></p>
    </div>
  </section>
</main>
</Base>
