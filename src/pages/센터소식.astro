---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('notice')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: Date) => d.toISOString().slice(0, 10);
---
<Base title="센터소식 메타 제목" description="센터소식 메타 설명" current="센터소식">
<div class="page-banner"><div class="wrap"><p class="breadcrumb"><a href={`${base}index.html`}>홈</a> › 센터소식</p><h1>센터소식</h1></div></div>

<main id="main" class="page-body"><div class="wrap">
  <div class="section-head">
    <span class="eyebrow">센터소식 소제목</span>
    <h2 style="font-size:1.6rem;margin:0;">센터소식 안내제목</h2>
    <p style="color:var(--ink-soft);">센터소식 안내문구</p>
  </div>
  {posts.length === 0 ? (
    <p>센터소식 빈 목록 안내문구</p>
  ) : (
    <ul class="news-list">
      {posts.map((post) => (
        <li>
          <a href={`${base}소식/${post.id}.html`}>
            <span class="t">
              <span class={post.data.category === '공지' ? 'badge notice' : 'badge'}>{post.data.category}</span>
              {post.data.title}
            </span>
            <span class="date">{fmt(post.data.date)}</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</div></main>
</Base>
