---
interface Props {
  title: string;
  description?: string;
  current?: string; // 현재 페이지 식별자 (aria-current 표시용)
}
const { title, description = '', current = '' } = Astro.props;
const base = import.meta.env.BASE_URL; // "/sitetest/"
const nav = [
  { id: '센터소개', href: `${base}센터소개.html`, label: '센터소개' },
  { id: '사업안내', href: `${base}사업안내.html`, label: '사업안내' },
  { id: '센터소식', href: `${base}센터소식.html`, label: '센터소식' },
  { id: '활동사진', href: `${base}활동사진.html`, label: '활동사진' },
  { id: '후원참여', href: `${base}후원참여.html`, label: '후원·참여' },
  { id: '오시는길', href: `${base}오시는길.html`, label: '오시는 길' },
];
---
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{title}</title>
{description && <meta name="description" content={description} />}
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css">
<link rel="stylesheet" href={`${base}styles.css`}>
<script src={`${base}a11y.js`} defer is:inline></script>
</head>
<body>
<a class="skip" href="#main">본문 바로가기</a>
<div id="a11y-live" class="sr-only" aria-live="polite"></div>

<div class="utility">
  <div class="wrap">
    <div class="contact">
      <span>📞 유틸리티바 전화번호</span>
      <span>✉️ <a href="mailto:info@goodvision.or.kr">유틸리티바 이메일</a></span>
    </div>
    <div class="a11y-controls">
      <span class="sr-only">글자 크기 조절 버튼 영역</span>
      <button id="txt-dec" type="button" aria-label="글자 작게">가–</button>
      <button id="txt-inc" type="button" aria-label="글자 크게">가+</button>
    </div>
  </div>
</div>

<header class="site">
  <div class="wrap masthead">
    <a class="brand" href={`${base}index.html`}>
      <span class="logo" aria-hidden="true">로고</span>
      <span class="name">사이트명<span class="tag">사이트 슬로건</span></span>
    </a>
    <nav class="primary" aria-label="주메뉴">
      <ul>
        {nav.map((item) => (
          <li><a href={item.href} aria-current={current === item.id ? 'page' : undefined}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<slot />

<footer class="site"><div class="wrap">
  <div class="fgrid">
    <div><h2>푸터 기관명</h2><p>푸터 소개문구</p><p>푸터 업무시간</p></div>
    <div><h2>푸터 바로가기 제목</h2><ul>{nav.slice(0, 4).map((item) => <li><a href={item.href}>{item.label}</a></li>)}</ul></div>
    <div><h2>푸터 연락처 제목</h2><ul><li>푸터 전화번호</li><li><a href="mailto:info@goodvision.or.kr">푸터 이메일</a></li><li>푸터 주소</li></ul></div>
  </div>
  <p class="legal">푸터 저작권·인증문구</p>
</div></footer>
</body>
</html>
